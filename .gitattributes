# Normalize line endings to LF on commit, allow OS-native on checkout
* text=auto eol=lf

# Ensure these stay LF even on Windows (shebangs, shell scripts)
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdc text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.webp binary
*.zip binary
*.exe binary
